rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }
    
    function isStaff() {
      return isSignedIn() && getUserRole() == 'staff';
    }
    
    function isStudent() {
      return isSignedIn() && getUserRole() == 'student';
    }
    
    function getStaffDept() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.dept;
    }
    
    function isAssignedStaff(studentId) {
      return exists(/databases/$(database)/documents/student_assignments/$(request.auth.uid + '_' + studentId));
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      // Users can read their own document (single get)
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // Admin can read all users (get + list)
      allow read: if isAdmin();
      
      // Staff can get individual students (for assignments)
      allow get: if isStaff() && isAssignedStaff(userId);

      // Staff can LIST students in their own department
      // (used by staff_dashboard.dart to load student list)
      allow list: if isStaff();

      // Allow small limit queries when not yet authenticated:
      // used for registration duplicate checks and master admin setup
      allow list: if isSignedIn() && request.query.limit <= 5;
      
      // Also allow unauthenticated small-limit queries
      // (ensureMasterAdminExists runs before login, checks email)
      allow list: if request.query.limit <= 2;
      
      // Users can create their own document during registration
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Allow master admin creation (runs signIn first then creates/sets doc)
      allow create: if true;
      
      // Users can update their own document (except protected fields)
      allow update: if isSignedIn() && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'totalFee', 'paidFee', 'status']);
      
      // Admin can update any user
      allow update: if isAdmin();
      
      // Admin can delete users
      allow delete: if isAdmin();
    }
    
    // ============================================
    // PAYMENTS COLLECTION
    // ============================================
    match /payments/{paymentId} {
      // Students can read (get) their own payment documents
      // Note: We check studentId from resource.data only when document exists.
      // For non-existent doc gets (doc.get() returns exists=false), Firestore
      // does NOT evaluate resource.data — allow student gets by UID prefix match.
      allow get: if isSignedIn() && (
        // Document exists and belongs to this student
        (resource != null && resource.data.studentId == request.auth.uid)
        // OR the payment document ID starts with the student's UID
        // (paymentId format: uid_semester_FeeType)
        || paymentId.matches(request.auth.uid + '.*')
      );
      
      // Students can list their own payments
      allow list: if isStudent() && request.query.filters.size() > 0;
      
      // Staff can get payments for students in their department
      allow get: if isStaff() && resource != null && isAssignedStaff(resource.data.studentId);
      
      // Staff can LIST all payments filtered by their department
      // (used by staff_dashboard.dart: .where('dept', isEqualTo: staffDept))
      allow list: if isStaff();

      // Admin can read all payments
      allow read: if isAdmin();
      
      // Students can create payments for themselves
      allow create: if isStudent() 
                    && request.resource.data.studentId == request.auth.uid
                    && request.resource.data.status in ['pending', 'under_review'];
      
      // Only admin can update payments (verify/reject)
      allow update: if isAdmin();
      
      // Only admin can delete payments
      allow delete: if isAdmin();
    }
    
    // ============================================
    // FEE STRUCTURES COLLECTION
    // ============================================
    match /fee_structures/{feeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // ============================================
    // ACADEMIC YEARS COLLECTION
    // ============================================
    match /academic_years/{yearId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // ============================================
    // SEMESTERS COLLECTION
    // ============================================
    match /semesters/{semesterId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // ============================================
    // DEPARTMENTS COLLECTION
    // ============================================
    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // ============================================
    // QUOTAS COLLECTION
    // ============================================
    match /quotas/{quotaId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // ============================================
    // NOTIFICATIONS COLLECTION
    // ============================================
    match /notifications/{notificationId} {
      // Users can get their own notification by document ID
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Users can LIST/QUERY their own notifications
      // (getUnreadNotificationCount, getUnreadCountStream, NotificationsScreen)
      allow list: if isSignedIn();
      
      // Admin can read all
      allow read: if isAdmin();
      
      // Users can update their own notifications (mark as read / received)
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['read', 'readAt', 'received', 'receivedAt']);
      
      // Allow create from app and Cloud Functions
      allow create: if true;
      
      // Admin can delete
      allow delete: if isAdmin();
    }
    
    // ============================================
    // STUDENT ASSIGNMENTS COLLECTION
    // ============================================
    match /student_assignments/{assignmentId} {
      allow read: if isStaff() && resource.data.staffId == request.auth.uid;
      allow read: if isStudent() && resource.data.studentId == request.auth.uid;
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ============================================
    // MASTER LISTS (For Registration)
    // ============================================
    match /student_master_list/{studentId} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
      allow update: if isSignedIn();
    }

    match /staff_master_list/{staffId} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
      allow update: if isSignedIn();
    }

    // ============================================
    // NO DUE CERTIFICATES COLLECTION
    // ============================================
    match /no_due_certificates/{certDocId} {
      // Students can read/write their own certificate
      allow read, write: if isSignedIn() && certDocId.startsWith(request.auth.uid + "_");
      
      // Staff can read assigned student certificates
      allow read: if isStaff() && isAssignedStaff(certDocId.split("_")[0]);

      // Admin can read/write all
      allow read, write: if isAdmin();

      // Public certificate verification by certId (open list for certificate lookup)
      allow list: if true;
    }
  }
}
